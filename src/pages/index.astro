---
import Layout from "@/layouts/Layout.astro";
import SignHotspot from "@/components/SignHotspot.astro";
import { Image } from "astro:assets";
import diner from "@/assets/hero/diner-night.png";
---
<Layout title="Ian Luna" description="Creative leader. Writer. Storyteller." sceneName="EXT. THE LAST STOP DINER — DUSK" frameNumber="001">
  <main id="main" class="stage">
    <div class="frame">
      <Image src={diner}
        alt="The Last Stop Diner at dusk. IAN LUNA marquee, WORK in green, ABOUT, HEARSAY signs lit on the building."
        widths={[640, 1280, 1920, 2560]} sizes="100vw"
        formats={["avif", "webp"]} loading="eager" fetchpriority="high"
        class="backdrop" />

      <!-- Tuned to W3 deployed crop -->
      <SignHotspot label="WORK" href="/work" color="work"
        ariaLabel="WORK. Case studies."
        top="35%" left="47%" width="25%" height="22%"
        flickerDelay="0s" hoverCopy="See the work" hintPosition="above" />
      <SignHotspot label="ABOUT" href="/about" color="about"
        ariaLabel="ABOUT. Bio and resume."
        top="36%" left="32%" width="9%" height="9%"
        flickerDelay="2.1s" hoverCopy="Who he is" hintPosition="above" />
      <SignHotspot label="HEARSAY" href="/hearsay" color="hearsay"
        ariaLabel="HEARSAY. Testimonials."
        top="46%" left="18%" width="10%" height="8%"
        flickerDelay="4.3s" hoverCopy="What they say" hintPosition="right" />
    </div>
  </main>
</Layout>

<style>
  .stage {
    height: calc(100vh - var(--frame-bar-h) * 2);
    min-height: 240px;
    display: flex; align-items: center; justify-content: center;
    padding: 0; background: var(--color-silhouette);
    overflow: hidden; position: relative;
    margin-top: var(--frame-bar-h);
  }
  .frame {
    position: relative;
    width: 100vw; height: 100%;
    margin: 0 auto; overflow: hidden;
  }
  .backdrop {
    width: 100%; height: 100%; display: block;
    object-fit: cover; object-position: center;
    z-index: 1;
    animation: world-breathe 14s ease-in-out infinite;
  }
  @keyframes world-breathe {
    0%, 100% { filter: brightness(1) saturate(1.02); }
    50%      { filter: brightness(1.04) saturate(1.05); }
  }
  @media (prefers-reduced-motion: reduce) { .backdrop { animation: none; } }
</style>
