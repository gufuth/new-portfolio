---
import Layout from "@/layouts/Layout.astro";
import SignHotspot from "@/components/SignHotspot.astro";
import { Image, getImage } from "astro:assets";
import diner from "@/assets/hero/diner-night.png";

const posterImage = await getImage({ src: diner, format: "webp", width: 1280 });
---
<Layout title="Ian Luna" description="Creative leader. Writer. Storyteller.">
  <main id="main" class="stage">
    <div class="frame">
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster={posterImage.src}
        aria-label="The Last Stop Diner at dusk. Neon signs lit, station wagon parked in the lot."
      >
        <source src="/video/diner-loop.mp4" type="video/mp4" />
      </video>

      <SignHotspot
        label="WORK"
        href="/work"
        color="work"
        ariaLabel="WORK. Case studies."
        top="59%" left="32%" width="22%" height="18%"
        labelPosition="below"
        pulseDelay="0s"
      />
      <SignHotspot
        label="ABOUT"
        href="/about"
        color="about"
        ariaLabel="ABOUT. Bio and resume."
        top="62%" left="55%" width="14%" height="11%"
        labelPosition="below"
        pulseDelay="1.2s"
      />
      <SignHotspot
        label="HEARSAY"
        href="/hearsay"
        color="hearsay"
        ariaLabel="HEARSAY. Testimonials."
        top="58%" left="15%" width="12%" height="10%"
        labelPosition="below"
        pulseDelay="2.4s"
      />

      <p class="enter-hint" id="enter-hint">Click any sign to enter</p>
    </div>
  </main>
</Layout>

<style>
  .stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--color-silhouette);
  }
  .frame {
    position: relative;
    width: 100vw;
    max-width: min(177vh, 100vw);
    aspect-ratio: 16 / 9;
    margin: 0 auto;
  }
  .hero-video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .enter-hint {
    position: absolute;
    bottom: 3%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(0.7rem, 1.1vw, 0.85rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-cream);
    text-shadow: 0 0 12px rgba(242, 237, 230, 0.6), 0 0 24px rgba(242, 237, 230, 0.3);
    opacity: 0;
    margin: 0;
    pointer-events: none;
    animation: hint-show 6s var(--ease-cinematic) 1.2s 1 both;
  }
  @keyframes hint-show {
    0% { opacity: 0; transform: translate(-50%, 12px); }
    15%, 70% { opacity: 0.9; transform: translate(-50%, 0); }
    100% { opacity: 0; transform: translate(-50%, -8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .enter-hint { animation: none; opacity: 0.7; }
  }
</style>

<script>
  // Hide hint once user has interacted
  const hint = document.getElementById('enter-hint');
  const hideHint = () => { if (hint) hint.style.display = 'none'; };
  document.querySelectorAll('.sign-hotspot').forEach(el => {
    el.addEventListener('mouseenter', hideHint, { once: true });
    el.addEventListener('click', hideHint, { once: true });
  });

  // Reduced motion: pause video
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('video').forEach(v => {
      (v as HTMLVideoElement).pause();
      (v as HTMLVideoElement).removeAttribute('autoplay');
    });
  }
</script>
