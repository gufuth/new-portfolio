---
import Layout from "@/layouts/Layout.astro";
import SignHotspot from "@/components/SignHotspot.astro";
import { Image } from "astro:assets";
import diner from "@/assets/hero/diner-night.png";
---
<Layout title="Ian Luna" description="Creative leader. Writer. Storyteller.">
  <main id="main" class="stage">
    <div class="frame">
      <Image
        src={diner}
        alt="The Last Stop Diner at dusk. Painted neon signs reading IAN LUNA on the roof, WORK in green, ABOUT, and HEARSAY on the building. Single station wagon parked in the lot."
        widths={[640, 1280, 1920, 2560]}
        sizes="(max-width: 768px) 100vw, min(100vh, 100vw)"
        formats={["avif", "webp"]}
        loading="eager"
        fetchpriority="high"
        class="backdrop"
      />

      <!-- Hotspots over painted signs. Coords measured for 1769149471685.png (~590x589 square). -->

      <SignHotspot
        label="WORK"
        href="/work"
        color="work"
        ariaLabel="WORK. Case studies."
        top="67%" left="35%" width="30%" height="14%"
        pulseDelay="0.6s"
        hintPosition="below"
      />

      <SignHotspot
        label="ABOUT"
        href="/about"
        color="about"
        ariaLabel="ABOUT. Bio and resume."
        top="51%" left="0%" width="18%" height="10%"
        pulseDelay="1.2s"
        hintPosition="right"
      />

      <SignHotspot
        label="HEARSAY"
        href="/hearsay"
        color="hearsay"
        ariaLabel="HEARSAY. Testimonials."
        top="64%" left="8%" width="14%" height="6%"
        pulseDelay="1.8s"
        hintPosition="right"
      />

      <p class="enter-hint" id="enter-hint">Click any sign to enter</p>
    </div>
  </main>
</Layout>

<style>
  .stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--color-silhouette);
    overflow: hidden;
  }
  .frame {
    position: relative;
    width: 100vw;
    max-width: min(100vh, 100vw);
    aspect-ratio: 1 / 1;
    margin: 0 auto;
  }
  .backdrop {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }
  .enter-hint {
    position: absolute;
    bottom: 3%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1vw, 0.78rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-cream);
    text-shadow: 0 0 12px rgba(242, 237, 230, 0.5), 0 0 24px rgba(242, 237, 230, 0.3);
    opacity: 0;
    margin: 0;
    pointer-events: none;
    animation: hint-show 6s var(--ease-cinematic) 2.6s 1 both;
  }
  @keyframes hint-show {
    0% { opacity: 0; transform: translate(-50%, 8px); }
    20%, 75% { opacity: 0.9; transform: translate(-50%, 0); }
    100% { opacity: 0; transform: translate(-50%, -8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .enter-hint { animation: none; opacity: 0.6; }
  }
</style>

<script>
  /* Hide enter hint once user has interacted with any hotspot */
  const hint = document.getElementById('enter-hint');
  const hide = () => { if (hint) hint.style.display = 'none'; };
  document.querySelectorAll('.hotspot').forEach(el => {
    el.addEventListener('mouseenter', hide, { once: true });
    el.addEventListener('click', hide, { once: true });
  });
</script>
