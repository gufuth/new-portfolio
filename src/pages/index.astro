---
import Layout from "@/layouts/Layout.astro";
import SignHotspot from "@/components/SignHotspot.astro";
import ParticlesField from "@/components/ParticlesField.astro";
import CursorSpotlight from "@/components/CursorSpotlight.astro";
import NoirCursor from "@/components/NoirCursor.astro";
import { Image } from "astro:assets";
import diner from "@/assets/hero/diner-scene.png";
---
<Layout title="Ian Luna" description="Creative leader. Writer. Storyteller.">
  <main id="main" class="stage">
    <div class="frame">
      <!-- L1: backdrop -->
      <Image src={diner}
        alt="The Last Stop Diner at dusk. IAN LUNA marquee, WORK in green, ABOUT, HEARSAY signs lit on the building."
        widths={[640, 1280, 1920, 2560]} sizes="(max-width: 768px) 100vw, 100vw"
        formats={["avif", "webp"]} loading="eager" fetchpriority="high"
        class="backdrop world-breathe" />

      <!-- L4: cursor-driven spotlight -->
      <CursorSpotlight />

      <!-- L2: ambient particles -->
      <ParticlesField count={70} />

      <!-- L3+L6: hotspots with neon flicker and in-world hover copy -->
      <SignHotspot label="WORK" href="/work" color="work"
        ariaLabel="WORK. Case studies."
        top="36%" left="40%" width="25%" height="14%"
        flickerDelay="0s"
        hoverCopy="See the work" />
      <SignHotspot label="ABOUT" href="/about" color="about"
        ariaLabel="ABOUT. Bio and resume."
        top="42%" left="13%" width="14%" height="10%"
        flickerDelay="2.1s"
        hoverCopy="Who he is" />
      <SignHotspot label="HEARSAY" href="/hearsay" color="hearsay"
        ariaLabel="HEARSAY. Testimonials."
        top="50%" left="20%" width="12%" height="7%"
        flickerDelay="4.3s"
        hoverCopy="What they say" />

      <!-- Entry sequence overlay (fade from black on load) -->
      <div class="entry-veil" aria-hidden="true"></div>

      <!-- Persistent diner-style instruction -->
      <p class="enter-hint" id="enter-hint">— Step into the diner —</p>
    </div>

    <!-- L6: noir cursor -->
    <NoirCursor />
  </main>
</Layout>

<style>
  .stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--color-silhouette);
    overflow: hidden;
    position: relative;
  }
  .frame {
    position: relative;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    margin: 0 auto;
    overflow: hidden;
  }
  .backdrop {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }
  .world-breathe {
    animation: world-pulse 12s ease-in-out infinite;
  }
  @keyframes world-pulse {
    0%, 100% { filter: brightness(1) contrast(1.02) saturate(1.02); }
    50%      { filter: brightness(1.05) contrast(1) saturate(1.05); }
  }

  /* Entry sequence — fade from black on first load */
  .entry-veil {
    position: absolute;
    inset: 0;
    background: var(--color-silhouette);
    pointer-events: none;
    z-index: 5;
    animation: entry-fade 1.6s var(--ease-cinematic) 1 forwards;
  }
  @keyframes entry-fade {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  .enter-hint {
    position: absolute;
    bottom: 4%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(0.7rem, 1.05vw, 0.85rem);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-cream);
    text-shadow: 0 0 12px rgba(242, 237, 230, 0.6), 0 0 24px rgba(242, 237, 230, 0.3);
    opacity: 0;
    margin: 0;
    pointer-events: none;
    z-index: 6;
    animation: hint-in 1.4s var(--ease-cinematic) 2s 1 forwards, hint-breathe 3.5s ease-in-out 3.4s infinite;
  }
  @keyframes hint-in {
    from { opacity: 0; transform: translate(-50%, 10px); }
    to   { opacity: 0.85; transform: translate(-50%, 0); }
  }
  @keyframes hint-breathe {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.9; }
  }
  .enter-hint.dismissed {
    animation: hint-out 0.5s var(--ease-cinematic) forwards;
  }
  @keyframes hint-out {
    to { opacity: 0; transform: translate(-50%, -8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .world-breathe, .entry-veil, .enter-hint { animation: none; }
    .entry-veil { display: none; }
    .enter-hint { opacity: 0.7; }
  }
</style>

<script>
  const hint = document.getElementById('enter-hint');
  const dismiss = () => { if (hint) hint.classList.add('dismissed'); };
  document.querySelectorAll('.hotspot').forEach(el => {
    el.addEventListener('mouseenter', dismiss, { once: true });
    el.addEventListener('click', dismiss, { once: true });
  });
</script>
