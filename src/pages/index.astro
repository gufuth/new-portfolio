---
import Layout from "@/layouts/Layout.astro";
import NeonText from "@/components/NeonText.astro";
import NeonSign from "@/components/NeonSign.astro";
import { Image } from "astro:assets";
import diner from "@/assets/hero/diner-clean.png";
---
<Layout title="Ian Luna" description="Creative leader. Writer. Storyteller.">
  <main id="main" class="stage">
    <div class="frame">
      <Image
        src={diner}
        alt="Last Stop Diner exterior at dusk, sodium-green parking lot, blank illuminated marquee, single station wagon parked at right."
        widths={[640, 1280, 1920, 2560]}
        sizes="(max-width: 768px) 100vw, min(177vh, 100vw)"
        formats={["avif", "webp"]}
        loading="eager"
        fetchpriority="high"
        class="backdrop"
      />

      <!-- IAN LUNA marquee — overlaid on the blank illuminated marquee box on the roof -->
      <div class="marquee-mount" aria-hidden="false">
        <NeonText
          text="IAN LUNA"
          color="marquee"
          size="clamp(0.9rem, 2.3vw, 1.9rem)"
          tracking="0.18em"
          weight={900}
        />
      </div>

      <!-- Three navigation neon signs positioned on the building front -->
      <NeonSign
        label="WORK"
        href="/work"
        color="work"
        size="clamp(1.4rem, 4.2vw, 3.4rem)"
        top="56%" left="48%"
        weight={900}
        tracking="0.12em"
        flickerDelay="0s"
      />
      <NeonSign
        label="ABOUT"
        href="/about"
        color="about"
        size="clamp(0.7rem, 1.7vw, 1.4rem)"
        top="58%" left="72%"
        weight={900}
        tracking="0.18em"
        flickerDelay="1.4s"
      />
      <NeonSign
        label="HEARSAY"
        href="/hearsay"
        color="hearsay"
        size="clamp(0.7rem, 1.7vw, 1.4rem)"
        top="58%" left="26%"
        weight={900}
        tracking="0.18em"
        flickerDelay="2.8s"
      />

      <p class="enter-hint" id="enter-hint">Click any sign to enter</p>
    </div>
  </main>
</Layout>

<style>
  .stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: var(--color-silhouette);
    overflow: hidden;
  }
  .frame {
    position: relative;
    width: 100vw;
    max-width: min(177vh, 100vw);
    aspect-ratio: 16 / 9;
    margin: 0 auto;
  }
  .backdrop {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }
  .marquee-mount {
    position: absolute;
    top: 26%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: none;
  }
  .enter-hint {
    position: absolute;
    bottom: 4%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1vw, 0.78rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-cream);
    text-shadow: 0 0 12px rgba(242, 237, 230, 0.5);
    opacity: 0;
    margin: 0;
    pointer-events: none;
    animation: hint-show 6s var(--ease-cinematic) 1.4s 1 both;
  }
  @keyframes hint-show {
    0% { opacity: 0; transform: translate(-50%, 12px); }
    15%, 75% { opacity: 0.85; transform: translate(-50%, 0); }
    100% { opacity: 0; transform: translate(-50%, -8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .enter-hint { animation: none; opacity: 0.6; }
  }
</style>

<script>
  const hint = document.getElementById('enter-hint');
  const hide = () => { if (hint) hint.style.display = 'none'; };
  document.querySelectorAll('.neon-sign').forEach(el => {
    el.addEventListener('mouseenter', hide, { once: true });
    el.addEventListener('click', hide, { once: true });
  });
</script>
