---
import Layout from "@/layouts/Layout.astro";
import SignHotspot from "@/components/SignHotspot.astro";
import { Image } from "astro:assets";
import diner from "@/assets/hero/diner-night.png";
---
<Layout title="Ian Luna" description="Creative leader. Writer. Storyteller.">
  <main id="main" class="stage">
    <div class="frame">
      <Image
        src={diner}
        alt="The Last Stop Diner at dusk. Neon signs lit, station wagon parked in the lot. Click any sign to enter."
        widths={[640, 1280, 1920, 2560]}
        sizes="(max-width: 768px) 100vw, min(100vh, 100vw)"
        formats={["avif", "webp"]}
        loading="eager"
        fetchpriority="high"
        class="hero-img"
      />

      <!-- Hotspots positioned as % of the image container. Coordinates tuned for 1769149471685.png. -->
      <SignHotspot
        label="WORK"
        href="/work"
        color="work"
        ariaLabel="WORK. Case studies."
        top="62%" left="36%" width="30%" height="17%"
      />
      <SignHotspot
        label="ABOUT"
        href="/about"
        color="about"
        ariaLabel="ABOUT. Bio and resume."
        top="51%" left="3%" width="18%" height="11%"
      />
      <SignHotspot
        label="HEARSAY"
        href="/hearsay"
        color="hearsay"
        ariaLabel="HEARSAY. Testimonials."
        top="62%" left="8%" width="14%" height="6%"
      />
    </div>
  </main>
</Layout>

<style>
  .stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .frame {
    position: relative;
    width: 100vw;
    max-width: min(100vh, 100vw);
    aspect-ratio: 1 / 1;
    margin: 0 auto;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }
  @media (max-width: 768px) {
    .frame { max-width: 100vw; }
  }
</style>
