---
import Layout from "@/layouts/Layout.astro";
import SignHotspot from "@/components/SignHotspot.astro";
import { Image } from "astro:assets";
import diner from "@/assets/hero/diner-night.png";
---
<Layout
  title="Ian Luna"
  description="Creative Director and Brand Strategist. Sixteen years writing for brands that want to be seen."
  sceneName="EXT. THE LAST STOP DINER — DUSK"
  frameNumber="001"
>
  <main id="main" class="stage">
    <div class="frame">
      <Image src={diner}
        alt="The Last Stop Diner at dusk. WORK painted in lime-green block neon across the front plate-glass window. IAN LUNA marquee fully visible on the roof. ABOUT marquee at front-left. Magenta-lit back-door at the right side where the building turns. A vintage station wagon parked close in the left foreground. One figure visible inside through the windows."
        widths={[768, 1280, 1536, 2048, 2560]} sizes="100vw"
        formats={["avif", "webp"]} loading="eager" fetchpriority="high"
        class="backdrop entry-zoom" />

      <SignHotspot label="WORK" href="/work" color="work"
        ariaLabel="WORK. Case studies."
        top="34%" left="30%" width="40%" height="38%"
        flickerDelay="2.5s" />
      <SignHotspot label="ABOUT" href="/about" color="about"
        ariaLabel="ABOUT. Bio and resume."
        top="14%" left="6%" width="13%" height="10%"
        flickerDelay="3.1s" />
      <SignHotspot label="HEARSAY" href="/hearsay" color="hearsay"
        ariaLabel="HEARSAY. Testimonials."
        top="32%" left="80%" width="14%" height="38%"
        flickerDelay="3.7s" />

      <span class="entry-hint" aria-hidden="true">Click any sign to enter</span>
    </div>
  </main>
</Layout>

<style>
  .stage {
    height: calc(100vh - var(--frame-bar-h) * 2);
    min-height: 240px;
    display: flex; align-items: center; justify-content: center;
    padding: 0; background: var(--color-silhouette);
    overflow: hidden; position: relative;
    margin-top: var(--frame-bar-h);
  }
  .frame { position: relative; width: 100vw; height: 100%; margin: 0 auto; overflow: hidden; }
  .backdrop {
    width: 100%; height: 100%; display: block;
    object-fit: cover; object-position: center 18%;
    z-index: 1;
    transform-origin: 50% 50%;
  }

  /* ENTRY ZOOM — lands wider, settles into hero crop over 2.5s, then ambient dolly continues. */
  .entry-zoom {
    animation:
      entry-dolly 2.5s var(--ease-cinematic) 1 forwards,
      ambient-dolly 60s var(--ease-cinematic) 2.5s infinite alternate;
  }
  @keyframes entry-dolly {
    0%   { transform: scale(1.15); }
    100% { transform: scale(1.00); }
  }
  @keyframes ambient-dolly {
    0%   { transform: scale(1.00); }
    100% { transform: scale(1.03); }
  }

  /* Entry hint — persistent low-opacity prompt; fades on first interaction. */
  .entry-hint {
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-cream);
    opacity: 0;
    z-index: 6;
    pointer-events: none;
    text-shadow: 0 0 12px rgba(10, 9, 8, 0.85), 0 1px 0 rgba(0, 0, 0, 0.4);
    animation: hint-rise 1.4s var(--ease-cinematic) 4.8s 1 forwards,
               hint-breathe 4.5s ease-in-out 6.4s infinite;
  }
  @keyframes hint-rise {
    0%   { opacity: 0; transform: translateX(-50%) translateY(8px); }
    100% { opacity: 0.55; transform: translateX(-50%) translateY(0); }
  }
  @keyframes hint-breathe {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.32; }
  }
  .frame.interacted .entry-hint {
    animation: hint-fade 0.4s linear forwards !important;
  }
  @keyframes hint-fade {
    to { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-zoom { animation: none; }
    .entry-hint { animation: hint-rise-rm 0.4s linear 0s 1 forwards; }
    @keyframes hint-rise-rm { to { opacity: 0.55; } }
  }
</style>

<script>
  // Hide entry hint on first interaction with any hotspot
  document.addEventListener("DOMContentLoaded", () => {
    const frameEl = document.querySelector(".frame");
    if (!frameEl) return;
    const hideHint = () => frameEl.classList.add("interacted");
    document.querySelectorAll(".hotspot").forEach((h) => {
      h.addEventListener("mouseenter", hideHint, { once: true });
      h.addEventListener("focus", hideHint, { once: true });
      h.addEventListener("click", hideHint, { once: true });
    });
  });
</script>
