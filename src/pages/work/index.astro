---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import booth from "@/assets/work/booth-billboards.png";
import bbMrbeast from "@/assets/work/billboards/mrbeast.png";
import bbGo from "@/assets/work/billboards/go.png";
import bbHometown from "@/assets/work/billboards/hometown.png";
import bbQuietIssue from "@/assets/work/billboards/quiet_issue.png";

interface Billboard {
  slug?: string;
  title: string;
  client: string;
  role: string;
  year: string;
  img: typeof bbMrbeast;
  top: string;   // viewport %
  left: string;  // viewport %
  width: string; // viewport % — controls visual scale (closer = bigger)
}

const billboards: Billboard[] = [
  { slug: "mrbeast", title: "BEAST MODE BANKING", client: "MoneyLion × Beast Games",
    role: "ACD, Copy", year: "2024–25",
    img: bbMrbeast, top: "37%", left: "36%", width: "16%" },
  { title: "GO", client: "Virgin Galactic",
    role: "ACD, Copy", year: "2023",
    img: bbGo, top: "35%", left: "53%", width: "12%" },
  { title: "HOMETOWN", client: "Nike — Air Force 1",
    role: "Senior Copy", year: "2022",
    img: bbHometown, top: "33%", left: "68%", width: "10%" },
  { title: "THE QUIET ISSUE", client: "The Atlantic × Audi",
    role: "Senior Copy", year: "2022",
    img: bbQuietIssue, top: "31%", left: "81%", width: "8%" },
];

const more = [
  { title: "Hours Later",                client: "1800 Tequila",       role: "Senior Copy",   year: "2021" },
  { title: "Born in Tequila",            client: "Jose Cuervo",        role: "Senior Copy",   year: "2021" },
  { title: "Apex Predator",              client: "Audi",               role: "Senior Copy",   year: "2020" },
  { title: "Doing Things, Off-Season",   client: "Outdoor Voices",     role: "Copy",          year: "2019" },
  { title: "Parking Lot Tour",           client: "Vans",               role: "Copy",          year: "2019" },
  { title: "Roar Money",                 client: "MoneyLion",          role: "Senior Copy",   year: "2023" },
  { title: "Swipe Right, Drive Away",    client: "car2go × Tinder",    role: "Copy",          year: "2017" },
  { title: "Internal Voice",             client: "SCOOBA Love",        role: "Creative Lead", year: "2018" },
  { title: "ROSEBUD",                    client: "Citizen Kane (spec)", role: "Writer",       year: "2024" },
];
---
<Layout
  title="Work — Ian Luna"
  description="Selected campaigns and copy systems."
  sceneName="INT. THE LAST STOP DINER — BOOTH"
  frameNumber="002"
>
  <main id="main" class="page">
    <section class="hero">
      <div class="hero-frame">
        <Image src={booth}
          alt="Inside a diner booth at 3am. Red vinyl seat, coffee cup steaming, folded newspaper on a formica table. Through the plate-glass window: a wet desert highway extending into the distance with four billboards along the side advertising case studies, a sodium-vapor green streetlamp on the curb, distant mountains, dusk sky. KROW lettering reflected on the inside of the window glass."
          widths={[768, 1280, 1536, 2048]} sizes="100vw"
          formats={["avif", "webp"]} loading="eager" fetchpriority="high"
          class="hero-img" />

        {billboards.map(b => {
          const positionStyle = `top: ${b.top}; left: ${b.left}; width: ${b.width};`;
          const vtName = b.slug ? `case-study-${b.slug}` : `case-study-pending-${b.title.replace(/\s+/g, "-").toLowerCase()}`;
          return b.slug ? (
            <a href={`/work/${b.slug}`}
               class="bb"
               style={`${positionStyle} view-transition-name: ${vtName};`}
               aria-label={`${b.title} — ${b.client}`}
               data-astro-prefetch>
              <Image src={b.img} alt={b.title} widths={[256, 384, 512, 768]} sizes={b.width} format="png" class="bb-img" />
            </a>
          ) : (
            <div class="bb pending"
                 style={`${positionStyle} view-transition-name: ${vtName};`}
                 aria-label={`${b.title} — ${b.client} (in preparation)`}
                 aria-disabled="true">
              <Image src={b.img} alt={b.title} widths={[256, 384, 512, 768]} sizes={b.width} format="png" class="bb-img" />
            </div>
          );
        })}
      </div>

      <div class="hero-meta">
        <a href="/" class="back-link" aria-label="Back outside">
          <span aria-hidden="true">←</span>
          <span>Back outside</span>
        </a>
        <span class="hero-cue">Click a billboard, or scroll for the full index</span>
      </div>
    </section>

    <section class="index">
      <header class="index-head">
        <h1 class="index-title">The Work</h1>
        <p class="index-sub">Sixteen years writing for brands that want to be seen.</p>
      </header>
      <section class="block">
        <header class="block-head"><span class="block-tag">Featured</span><span class="block-rule" aria-hidden="true"></span></header>
        <ol class="list">
          {billboards.map((b, i) => (
            <li class:list={["entry", !b.slug && "pending"]}>
              <span class="num">{String(i + 1).padStart(2, "0")}</span>
              {b.slug ? (
                <a href={`/work/${b.slug}`} class="entry-body" data-astro-prefetch>
                  <span class="entry-title">{b.title}</span>
                  <span class="entry-line">{b.client}<span class="dot">·</span>{b.role}<span class="dot">·</span>{b.year}</span>
                </a>
              ) : (
                <div class="entry-body" aria-disabled="true">
                  <span class="entry-title">{b.title}</span>
                  <span class="entry-line">{b.client}<span class="dot">·</span>{b.role}<span class="dot">·</span>{b.year}</span>
                  <span class="entry-status">In preparation</span>
                </div>
              )}
            </li>
          ))}
        </ol>
      </section>
      <section class="block">
        <header class="block-head"><span class="block-tag">Selected</span><span class="block-rule" aria-hidden="true"></span></header>
        <ol class="list" start={billboards.length + 1}>
          {more.map((e, i) => (
            <li class="entry pending">
              <span class="num">{String(billboards.length + i + 1).padStart(2, "0")}</span>
              <div class="entry-body" aria-disabled="true">
                <span class="entry-title">{e.title}</span>
                <span class="entry-line">{e.client}<span class="dot">·</span>{e.role}<span class="dot">·</span>{e.year}</span>
                <span class="entry-status">In preparation</span>
              </div>
            </li>
          ))}
        </ol>
      </section>
    </section>
  </main>
</Layout>

<style>
  .page { min-height: calc(100vh - var(--frame-bar-h) * 2); margin-top: var(--frame-bar-h); background: var(--color-silhouette); color: var(--color-cream); }
  .hero { height: calc(100vh - var(--frame-bar-h) * 2); min-height: 480px; position: relative; overflow: hidden; display: flex; flex-direction: column; }
  .hero-frame { flex: 1 1 auto; position: relative; overflow: hidden; }
  .hero-img { width: 100%; height: 100%; display: block; object-fit: cover; object-position: center; z-index: 1; }

  /* Photographic billboard PNGs — composited onto the highway scene */
  .bb {
    position: absolute;
    z-index: 5;
    display: block;
    text-decoration: none;
    cursor: pointer;
    transform-origin: bottom center;
    transition: filter 0.3s var(--ease-cinematic), transform 0.3s var(--ease-cinematic);
    filter: brightness(0.92) saturate(0.95) drop-shadow(0 8px 12px rgba(0,0,0,0.5));
  }
  .bb.pending { cursor: default; opacity: 0.85; }
  .bb:not(.pending):hover {
    filter: brightness(1.1) saturate(1.05) drop-shadow(0 10px 16px rgba(0,0,0,0.6));
    transform: scale(1.04);
  }
  .bb:focus-visible { outline: 2px solid var(--color-cream); outline-offset: 6px; border-radius: 4px; }
  .bb-img {
    display: block;
    width: 100%;
    height: auto;
    pointer-events: none;
  }

  .hero-meta { flex: 0 0 auto; display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-6); background: var(--color-silhouette); border-top: 1px solid color-mix(in srgb, var(--color-cream) 10%, transparent); }
  .back-link { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.28em; text-transform: uppercase; color: var(--color-muted); text-decoration: none; display: inline-flex; gap: 0.5em; transition: color 0.2s; }
  .back-link:hover { color: var(--color-cream); }
  .hero-cue { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-marquee-warm); opacity: 0.7; }

  .index { padding: var(--space-24) var(--space-6) var(--space-32); max-width: 920px; margin: 0 auto; }
  .index-head { border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 14%, transparent); padding-bottom: var(--space-10); margin-bottom: var(--space-16); }
  .index-title { font-family: var(--font-display); font-weight: 900; font-size: clamp(var(--text-3xl), 7vw, var(--text-4xl)); line-height: 0.95; letter-spacing: -0.02em; margin: 0 0 var(--space-4); }
  .index-sub { font-family: var(--font-body); font-size: var(--text-base); line-height: 1.55; color: var(--color-muted); max-width: 60ch; margin: 0; }
  .block { margin-bottom: var(--space-20); }
  .block-head { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6); }
  .block-tag { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.32em; text-transform: uppercase; color: var(--color-marquee-warm); }
  .block-rule { flex: 1 1 auto; height: 1px; background: color-mix(in srgb, var(--color-cream) 14%, transparent); }
  .list { list-style: none; padding: 0; margin: 0; }
  .entry { display: grid; grid-template-columns: 60px 1fr; gap: var(--space-4); padding: var(--space-5) 0; border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 8%, transparent); align-items: baseline; }
  .entry:last-child { border-bottom: none; }
  .num { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.18em; color: var(--color-muted); padding-top: 0.5em; }
  .entry-body { display: flex; flex-direction: column; gap: 0.3em; text-decoration: none; color: var(--color-cream); transition: padding 0.25s var(--ease-cinematic), background 0.25s; padding: 0; }
  a.entry-body:hover { padding-left: var(--space-3); background: linear-gradient(to right, color-mix(in srgb, var(--color-neon-work) 8%, transparent), transparent 30%); }
  .pending .entry-body { color: color-mix(in srgb, var(--color-cream) 55%, transparent); cursor: default; }
  .entry-title { font-family: var(--font-display); font-weight: 700; font-size: clamp(var(--text-xl), 3vw, var(--text-3xl)); line-height: 1.05; letter-spacing: -0.01em; }
  .entry-line { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-muted); }
  .dot { margin: 0 0.5em; opacity: 0.4; }
  .entry-status { font-family: var(--font-mono); font-size: var(--text-3xs); letter-spacing: 0.28em; text-transform: uppercase; color: var(--color-marquee-warm); opacity: 0.55; }
</style>
