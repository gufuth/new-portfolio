---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import booth from "@/assets/work/booth-billboards.png";

// Case studies sourced from drafts/sidequest_portfolio_site/case_studies_v1.md
// Architecture per design_system_and_throughline_2026_05_27.md:
// /work = booth interior view through window to highway with case-study billboards.
// Featured 3-4 case studies are billboards visible IN the hero image (clickable via SignHotspot).
// Full case study index lives BELOW the hero as editorial type — no menu metaphor, no kitsch.

interface Entry {
  slug?: string;          // present = case study page exists. absent = WIP placeholder.
  title: string;
  client: string;
  role: string;
  year: string;
}

const featured: Entry[] = [
  { slug: "mrbeast", title: "Beast Mode Banking", client: "MoneyLion × Beast Games (Amazon Prime)", role: "ACD, Copy", year: "2024–25" },
  { title: "GO",                       client: "Virgin Galactic",                role: "ACD, Copy",       year: "2023" },
  { title: "Hometown",                 client: "Nike — Air Force 1",             role: "Senior Copy",     year: "2022" },
  { title: "The Quiet Issue",          client: "The Atlantic × Audi",            role: "Senior Copy",     year: "2022" },
];

const more: Entry[] = [
  { title: "Hours Later",                 client: "1800 Tequila",          role: "Senior Copy",  year: "2021" },
  { title: "Born in Tequila",             client: "Jose Cuervo",           role: "Senior Copy",  year: "2021" },
  { title: "Apex Predator",               client: "Audi",                  role: "Senior Copy",  year: "2020" },
  { title: "Doing Things, Off-Season",    client: "Outdoor Voices",        role: "Copy",         year: "2019" },
  { title: "Parking Lot Tour",            client: "Vans",                  role: "Copy",         year: "2019" },
  { title: "Roar Money",                  client: "MoneyLion",             role: "Senior Copy",  year: "2023" },
  { title: "Swipe Right, Drive Away",     client: "car2go × Tinder",       role: "Copy",         year: "2017" },
  { title: "Internal Voice",              client: "SCOOBA Love",           role: "Creative Lead", year: "2018" },
  { title: "ROSEBUD",                     client: "Citizen Kane (spec)",   role: "Writer",       year: "2024" },
];
---
<Layout
  title="Work — Ian Luna"
  description="Selected campaigns and copy systems. Beast Mode Banking, Virgin Galactic, Nike, The Atlantic × Audi, and others."
  sceneName="INT. THE LAST STOP DINER — BOOTH"
  frameNumber="002"
>
  <main id="main" class="page">
    <!-- HERO: booth interior, billboards visible through plate-glass window on the highway -->
    <section class="hero">
      <div class="hero-frame">
        <Image src={booth}
          alt="Inside a 1950s American diner booth at 3am. Coffee cup on the formica table, newspaper, red vinyl bench. Through the plate-glass window: a wet desert highway at dusk with four lit billboards visible at different distances — BEAST MODE BANKING in green, GO, HOMETOWN, THE QUIET ISSUE. The WORK painted neon from the front face is visible in reverse on the inside of the glass."
          widths={[768, 1280, 1536, 2048, 2560]} sizes="100vw"
          formats={["avif", "webp"]} loading="eager" fetchpriority="high"
          class="hero-img" />

        <a href="/work/mrbeast" class="bb bb-1" aria-label="Beast Mode Banking — MoneyLion × Beast Games" data-astro-prefetch>
          <span class="sr-only">Beast Mode Banking</span>
        </a>
        <div class="bb bb-2 disabled" aria-label="GO — Virgin Galactic (in preparation)" aria-disabled="true">
          <span class="sr-only">GO — Virgin Galactic</span>
        </div>
        <div class="bb bb-3 disabled" aria-label="Hometown — Nike (in preparation)" aria-disabled="true">
          <span class="sr-only">Hometown — Nike</span>
        </div>
        <div class="bb bb-4 disabled" aria-label="The Quiet Issue — The Atlantic × Audi (in preparation)" aria-disabled="true">
          <span class="sr-only">The Quiet Issue</span>
        </div>
      </div>

      <div class="hero-meta">
        <a href="/" class="back-link" aria-label="Back to the diner exterior">
          <span aria-hidden="true">←</span>
          <span>Back outside</span>
        </a>
        <span class="hero-cue">Click a billboard to enter, or scroll for the full index.</span>
      </div>
    </section>

    <!-- EDITORIAL INDEX: every case study listed cleanly, no menu metaphor -->
    <section class="index">
      <header class="index-head">
        <h1 class="index-title">The Work</h1>
        <p class="index-sub">Sixteen years writing for brands that want to be seen. Below are the campaigns and copy systems that anchored the work.</p>
      </header>

      <section class="block">
        <header class="block-head">
          <span class="block-tag">Featured</span>
          <span class="block-rule" aria-hidden="true"></span>
        </header>
        <ol class="list">
          {featured.map((e, i) => (
            <li class:list={["entry", !e.slug && "pending"]}>
              <span class="num">{String(i + 1).padStart(2, "0")}</span>
              {e.slug ? (
                <a href={`/work/${e.slug}`} class="entry-body" data-astro-prefetch>
                  <span class="entry-title">{e.title}</span>
                  <span class="entry-line">{e.client}<span class="dot">·</span>{e.role}<span class="dot">·</span>{e.year}</span>
                </a>
              ) : (
                <div class="entry-body" aria-disabled="true">
                  <span class="entry-title">{e.title}</span>
                  <span class="entry-line">{e.client}<span class="dot">·</span>{e.role}<span class="dot">·</span>{e.year}</span>
                  <span class="entry-status">In preparation</span>
                </div>
              )}
            </li>
          ))}
        </ol>
      </section>

      <section class="block">
        <header class="block-head">
          <span class="block-tag">Selected</span>
          <span class="block-rule" aria-hidden="true"></span>
        </header>
        <ol class="list" start={featured.length + 1}>
          {more.map((e, i) => (
            <li class="entry pending">
              <span class="num">{String(featured.length + i + 1).padStart(2, "0")}</span>
              <div class="entry-body" aria-disabled="true">
                <span class="entry-title">{e.title}</span>
                <span class="entry-line">{e.client}<span class="dot">·</span>{e.role}<span class="dot">·</span>{e.year}</span>
                <span class="entry-status">In preparation</span>
              </div>
            </li>
          ))}
        </ol>
      </section>
    </section>
  </main>
</Layout>

<style>
  .page {
    min-height: calc(100vh - var(--frame-bar-h) * 2);
    margin-top: var(--frame-bar-h);
    background: var(--color-silhouette);
    color: var(--color-cream);
  }

  /* HERO — booth view with clickable billboards */
  .hero {
    height: calc(100vh - var(--frame-bar-h) * 2);
    min-height: 480px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .hero-frame {
    flex: 1 1 auto;
    position: relative;
    overflow: hidden;
  }
  .hero-img {
    width: 100%; height: 100%; display: block;
    object-fit: cover; object-position: center;
    z-index: 1;
  }

  /* Billboard hotspots — positioned on the billboards visible through the window in the asset.
     Coords are approximate to v_work_booth_billboards.png — operator tunes if needed. */
  .bb {
    position: absolute;
    z-index: 5;
    display: block;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
    transition: background 0.3s var(--ease-cinematic), border 0.3s var(--ease-cinematic), box-shadow 0.3s var(--ease-cinematic);
  }
  .bb:not(.disabled):hover {
    background: rgba(91, 255, 106, 0.05);
    border-color: color-mix(in srgb, var(--color-neon-work) 50%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-neon-work) 40%, transparent);
  }
  .bb:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 4px;
  }
  .bb.disabled { cursor: default; opacity: 0.6; }

  /* Approximate billboard coords on the v_work asset — adjust if the asset is regenerated */
  .bb-1 { top: 18%; left: 12%; width: 18%; height: 28%; }   /* BEAST MODE BANKING — closest, left */
  .bb-2 { top: 22%; left: 33%; width: 11%; height: 22%; }   /* GO — mid-distance, center-left */
  .bb-3 { top: 24%; left: 48%; width: 14%; height: 22%; }   /* HOMETOWN — center-right */
  .bb-4 { top: 22%; left: 65%; width: 20%; height: 24%; }   /* WORK / Quiet Issue — far distance, large */

  .hero-meta {
    flex: 0 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: var(--color-silhouette);
    border-top: 1px solid color-mix(in srgb, var(--color-cream) 10%, transparent);
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    display: inline-flex;
    gap: 0.5em;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-cream); }
  .hero-cue {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-marquee-warm);
    opacity: 0.7;
  }

  /* EDITORIAL INDEX — clean type, no menu metaphor, no kitsch */
  .index {
    padding: var(--space-24) var(--space-6) var(--space-32);
    max-width: 920px;
    margin: 0 auto;
  }
  .index-head {
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 14%, transparent);
    padding-bottom: var(--space-10);
    margin-bottom: var(--space-16);
  }
  .index-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(var(--text-3xl), 7vw, var(--text-4xl));
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-4);
  }
  .index-sub {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--color-muted);
    max-width: 60ch;
    margin: 0;
  }

  .block { margin-bottom: var(--space-20); }
  .block-head {
    display: flex; align-items: center; gap: var(--space-3);
    margin-bottom: var(--space-6);
  }
  .block-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-marquee-warm);
  }
  .block-rule {
    flex: 1 1 auto;
    height: 1px;
    background: color-mix(in srgb, var(--color-cream) 14%, transparent);
  }

  .list { list-style: none; padding: 0; margin: 0; }
  .entry {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-cream) 8%, transparent);
    align-items: baseline;
  }
  .entry:last-child { border-bottom: none; }
  .num {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.18em;
    color: var(--color-muted);
    padding-top: 0.5em;
  }
  .entry-body {
    display: flex; flex-direction: column; gap: 0.3em;
    text-decoration: none; color: var(--color-cream);
    transition: padding 0.25s var(--ease-cinematic), background 0.25s;
    padding: 0;
  }
  a.entry-body:hover {
    padding-left: var(--space-3);
    background: linear-gradient(to right, color-mix(in srgb, var(--color-neon-work) 8%, transparent), transparent 30%);
  }
  .pending .entry-body {
    color: color-mix(in srgb, var(--color-cream) 55%, transparent);
    cursor: default;
  }
  .entry-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .entry-line {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .dot { margin: 0 0.5em; opacity: 0.4; }
  .entry-status {
    font-family: var(--font-mono);
    font-size: var(--text-3xs);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-marquee-warm);
    opacity: 0.55;
  }

  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
</style>
