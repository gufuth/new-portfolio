---
interface Props {
  sceneName?: string;
  frameNumber?: string;
  role?: string;
  yearRange?: string;
}
const {
  sceneName = "EXT. DINER — DUSK",
  frameNumber = "001",
  role = "Creative Director · Brand Strategist",
  yearRange = "MMX — MMXXVI",
} = Astro.props;
const now = new Date();
const timestamp = `${String(now.getUTCHours()).padStart(2, "0")}:${String(now.getUTCMinutes()).padStart(2, "0")}`;
---
<div class="film-frame" data-transition-name="film-frame">
  <div class="bar top" data-transition-name="frame-top">
    <span class="meta meta-left">
      <span class="primary">Ian Luna</span>
      <span class="separator">·</span>
      <span class="role">{role}</span>
    </span>
    <span class="meta meta-right">
      <span class="years">{yearRange}</span>
      <span class="separator">·</span>
      <span class="frame">Frame {frameNumber}</span>
    </span>
  </div>
  <div class="stage-content">
    <slot />
  </div>
  <div class="bar bottom" data-transition-name="frame-bottom">
    <span class="meta meta-left">{sceneName}</span>
    <span class="meta meta-right">T {timestamp} UTC</span>
  </div>
</div>

<style>
  .film-frame {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 80;
    display: flex;
    flex-direction: column;
  }
  .bar {
    pointer-events: auto;
    height: var(--frame-bar-h);
    min-height: 28px;
    background: var(--color-frame-bar);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-4);
    flex: 0 0 auto;
  }
  .stage-content {
    flex: 1 1 auto;
    position: relative;
    pointer-events: none;
  }
  .stage-content > :global(*) { pointer-events: auto; }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-3xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0.78;
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
  }
  .meta-left { text-align: left; }
  .meta-right { text-align: right; }
  .primary { color: var(--color-cream); opacity: 1; }
  .separator { opacity: 0.4; }
  .role { font-style: normal; }
  .years { letter-spacing: 0.28em; }

  /* On small screens, hide the secondary half of each bar to keep the primary readable */
  @media (max-width: 640px) {
    .role, .years { display: none; }
    .meta .separator:first-of-type { display: none; }
  }

  .bar { view-transition-name: var(--vt-name, none); }
  .bar.top { view-transition-name: frame-top; }
  .bar.bottom { view-transition-name: frame-bottom; }
</style>
