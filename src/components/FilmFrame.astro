---
interface Props {
  sceneName?: string;
  frameNumber?: string;
  role?: string;
  yearRange?: string;
}
const {
  sceneName = "EXT. DINER â€” DUSK",
  frameNumber = "001",
  role = "Creative Director",
  yearRange = "MMX â€” MMXXVI",
} = Astro.props;
const now = new Date();
const timestamp = `${String(now.getUTCHours()).padStart(2, "0")}:${String(now.getUTCMinutes()).padStart(2, "0")}`;
---
<div class="film-frame" data-transition-name="film-frame">
  <div class="bar top" data-transition-name="frame-top"></div>
  <div class="stage-content">
    <slot />
  </div>
  <div class="bar bottom" data-transition-name="frame-bottom"></div>
</div>

<!-- META OVERLAY â€” sibling of bars, NOT inside them. View Transitions API does NOT
     snapshot this into the scaling pseudo-element. Bars scale freely; text stays sharp at rest. -->
<div class="frame-meta-overlay" aria-hidden="true">
  <div class="meta-row top">
    <span class="meta meta-left">
      <span class="primary">Ian Luna</span>
      <span class="separator">Â·</span>
      <span class="role">{role}</span>
    </span>
    <span class="meta meta-right">
      <span class="years">{yearRange}</span>
      <span class="separator">Â·</span>
      <span class="frame">Frame {frameNumber}</span>
    </span>
  </div>
  <div class="meta-row bottom">
    <span class="meta meta-left">{sceneName}</span>
    <span class="meta meta-right" data-live-time>T {timestamp} UTC</span>
  </div>
</div>

<style>

  /* META OVERLAY â€” sits ABOVE bars, NOT inside them, so View Transitions
     doesn't scale the text with the bars */
  .frame-meta-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 81;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .meta-row {
    height: var(--frame-bar-h);
    min-height: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-4);
    flex: 0 0 auto;
  }

  .film-frame {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 80;
    display: flex;
    flex-direction: column;
  }
  .bar {
    pointer-events: auto;
    height: var(--frame-bar-h);
    min-height: 28px;
    background: var(--color-frame-bar);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-4);
    flex: 0 0 auto;
  }
  .stage-content {
    flex: 1 1 auto;
    position: relative;
    pointer-events: none;
  }
  .stage-content > :global(*) { pointer-events: auto; }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-3xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0.78;
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
  }
  .meta-left { text-align: left; }
  .meta-right { text-align: right; }
  .primary { color: var(--color-cream); opacity: 1; }
  .separator { opacity: 0.4; }
  .role { font-style: normal; }
  .years { letter-spacing: 0.28em; }

  /* On small screens, hide the secondary half of each bar to keep the primary readable */
  @media (max-width: 640px) {
    .role, .years { display: none; }
    .meta .separator:first-of-type { display: none; }
  }

  /* FILMFRAME_LOCK: view-transition-names stripped from the bars â€” they caused the
     14x metadata-scale bug (deployed_review_2026_05_30 item 12). Cuts happen behind
     static bars; the bars never scale. Removed 2026-07-11 (oracle-caught regression). */
</style>

<script>
  function updateLiveTime() {
    const el = document.querySelector("[data-live-time]");
    if (!el) return;
    const now = new Date();
    const hh = String(now.getUTCHours()).padStart(2, "0");
    const mm = String(now.getUTCMinutes()).padStart(2, "0");
    el.textContent = `T ${hh}:${mm} UTC`;
  }
  updateLiveTime();
  setInterval(updateLiveTime, 60000);

  // A10: door bell on scene transition
  document.addEventListener("astro:before-preparation", () => {
    const bell = (window as any).__playDoorBell;
    if (typeof bell === "function") bell();
  });
</script>
