---
// Ambient audio layered loops — Web Audio API synth, per research_2026_05_29_round_2.md
// Layers: room tone (low filter noise) + neon hum (60Hz osc) + distant traffic (low rumble) + sparse vinyl crackle
// Persistent mute toggle, localStorage-backed
---
<button id="ambient-toggle" class="ambient-toggle" aria-label="Toggle ambient sound" type="button">
  <span class="ambient-icon" aria-hidden="true">♪</span>
  <span class="ambient-state">off</span>
</button>

<style>
  .ambient-toggle {
    position: fixed;
    top: calc(var(--frame-bar-h) + 16px);
    right: 24px;
    z-index: 90;
    background: transparent;
    border: 1px solid rgba(200, 180, 150, 0.20);
    border-radius: 24px;
    padding: 6px 14px 6px 10px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    backdrop-filter: blur(8px);
  }
  .ambient-toggle:hover {
    color: var(--color-cream);
    border-color: rgba(200, 180, 150, 0.45);
    background: rgba(10, 9, 8, 0.4);
  }
  .ambient-toggle[data-on="true"] { color: var(--color-neon-work); border-color: rgba(82, 240, 90, 0.4); }
  .ambient-icon { font-size: 12px; line-height: 1; }
  @media (max-width: 768px) {
    .ambient-toggle { top: calc(var(--frame-bar-h) + 8px); right: 12px; padding: 5px 10px 5px 8px; font-size: 9px; }
  }
</style>

<script>
  // Layered ambient audio engine — synth, no external files
  let audioCtx: AudioContext | null = null;
  let masterGain: GainNode | null = null;
  let layers: Array<{ stop: () => void }> = [];
  let isOn = false;

  function buildLayers() {
    if (!audioCtx || !masterGain) return [];
    const ctx = audioCtx;
    const built: Array<{ stop: () => void }> = [];

    // Layer 1: Room tone — pink noise through low-pass
    const noiseBufferSize = ctx.sampleRate * 4;
    const noiseBuffer = ctx.createBuffer(1, noiseBufferSize, ctx.sampleRate);
    const data = noiseBuffer.getChannelData(0);
    let b0=0,b1=0,b2=0,b3=0,b4=0,b5=0,b6=0;
    for (let i=0; i<noiseBufferSize; i++) {
      const white = Math.random()*2 - 1;
      b0 = 0.99886*b0 + white*0.0555179;
      b1 = 0.99332*b1 + white*0.0750759;
      b2 = 0.96900*b2 + white*0.1538520;
      b3 = 0.86650*b3 + white*0.3104856;
      b4 = 0.55000*b4 + white*0.5329522;
      b5 = -0.7616*b5 - white*0.0168980;
      data[i] = (b0+b1+b2+b3+b4+b5+b6+white*0.5362) * 0.11;
      b6 = white*0.115926;
    }
    const noise = ctx.createBufferSource();
    noise.buffer = noiseBuffer; noise.loop = true;
    const lp = ctx.createBiquadFilter();
    lp.type = "lowpass"; lp.frequency.value = 380; lp.Q.value = 0.7;
    const g1 = ctx.createGain(); g1.gain.value = 0.22;
    noise.connect(lp); lp.connect(g1); g1.connect(masterGain);
    noise.start();
    built.push({ stop: () => { noise.stop(); } });

    // Layer 2: Neon hum — 60Hz + 120Hz osc, very low
    const osc1 = ctx.createOscillator();
    osc1.type = "sine"; osc1.frequency.value = 60;
    const osc2 = ctx.createOscillator();
    osc2.type = "sine"; osc2.frequency.value = 120;
    const g2 = ctx.createGain(); g2.gain.value = 0.025;
    const g3 = ctx.createGain(); g3.gain.value = 0.012;
    osc1.connect(g2); g2.connect(masterGain);
    osc2.connect(g3); g3.connect(masterGain);
    osc1.start(); osc2.start();
    // Subtle modulation for "alive" feel
    const lfo = ctx.createOscillator();
    lfo.type = "sine"; lfo.frequency.value = 0.13;
    const lfoGain = ctx.createGain(); lfoGain.gain.value = 0.005;
    lfo.connect(lfoGain); lfoGain.connect(g2.gain);
    lfo.start();
    built.push({ stop: () => { osc1.stop(); osc2.stop(); lfo.stop(); } });

    // Layer 3: Distant traffic rumble — low-pass filtered brown-ish noise
    const rumbleBuffer = ctx.createBuffer(1, ctx.sampleRate * 6, ctx.sampleRate);
    const rumbleData = rumbleBuffer.getChannelData(0);
    let last = 0;
    for (let i=0; i<rumbleData.length; i++) {
      const w = Math.random()*2 - 1;
      last = (last + (0.02*w)) / 1.02;
      rumbleData[i] = last * 3.5;
    }
    const rumble = ctx.createBufferSource();
    rumble.buffer = rumbleBuffer; rumble.loop = true;
    const lp2 = ctx.createBiquadFilter();
    lp2.type = "lowpass"; lp2.frequency.value = 90;
    const g4 = ctx.createGain(); g4.gain.value = 0.18;
    rumble.connect(lp2); lp2.connect(g4); g4.connect(masterGain);
    rumble.start();
    built.push({ stop: () => { rumble.stop(); } });

    // Layer 4: Cicada / insect bed — high-frequency narrow-band noise
    const cicadaBufSize = ctx.sampleRate * 3;
    const cicadaBuffer = ctx.createBuffer(1, cicadaBufSize, ctx.sampleRate);
    const cd = cicadaBuffer.getChannelData(0);
    for (let i = 0; i < cicadaBufSize; i++) cd[i] = (Math.random() * 2 - 1);
    const cicada = ctx.createBufferSource();
    cicada.buffer = cicadaBuffer; cicada.loop = true;
    const cFilt = ctx.createBiquadFilter();
    cFilt.type = "bandpass"; cFilt.frequency.value = 2000; cFilt.Q.value = 12;
    const gCicada = ctx.createGain(); gCicada.gain.value = 0.012;
    // Subtle LFO modulation on cicada — gives natural chirp pulse
    const cLFO = ctx.createOscillator();
    cLFO.type = "sine"; cLFO.frequency.value = 2.5;
    const cLFOGain = ctx.createGain(); cLFOGain.gain.value = 0.008;
    cLFO.connect(cLFOGain); cLFOGain.connect(gCicada.gain);
    cicada.connect(cFilt); cFilt.connect(gCicada); gCicada.connect(masterGain);
    cicada.start(); cLFO.start();
    built.push({ stop: () => { cicada.stop(); cLFO.stop(); } });

    // Layer 5: Doppler-passing-car — scheduled every 25-40s
    let carTimer: number | null = null;
    const scheduleCar = () => {
      const delay = 25000 + Math.random() * 15000; // 25-40s
      carTimer = window.setTimeout(() => {
        if (!audioCtx || !masterGain) return;
        const t0 = audioCtx.currentTime;
        // Filtered noise burst — pitch sweeps via filter freq sweep
        const carBuf = audioCtx.createBuffer(1, audioCtx.sampleRate * 4, audioCtx.sampleRate);
        const cdata = carBuf.getChannelData(0);
        for (let i=0; i<cdata.length; i++) cdata[i] = (Math.random()*2-1) * 0.5;
        const car = audioCtx.createBufferSource();
        car.buffer = carBuf;
        const carFilt = audioCtx.createBiquadFilter();
        carFilt.type = "bandpass"; carFilt.frequency.value = 200; carFilt.Q.value = 1.2;
        const carGain = audioCtx.createGain(); carGain.gain.value = 0;
        const carPan = audioCtx.createStereoPanner(); carPan.pan.value = -1;
        car.connect(carFilt); carFilt.connect(carGain); carGain.connect(carPan); carPan.connect(masterGain);
        // Envelope
        carGain.gain.setValueAtTime(0, t0);
        carGain.gain.linearRampToValueAtTime(0.18, t0 + 1.5);
        carGain.gain.linearRampToValueAtTime(0.22, t0 + 2.0);
        carGain.gain.linearRampToValueAtTime(0.0, t0 + 3.8);
        // Doppler — filter freq sweeps up then down
        carFilt.frequency.setValueAtTime(160, t0);
        carFilt.frequency.linearRampToValueAtTime(320, t0 + 2.0);
        carFilt.frequency.linearRampToValueAtTime(140, t0 + 3.5);
        // Pan sweep left to right
        carPan.pan.setValueAtTime(-1, t0);
        carPan.pan.linearRampToValueAtTime(1, t0 + 3.5);
        car.start(t0); car.stop(t0 + 4);
        scheduleCar();
      }, delay);
    };
    scheduleCar();
    built.push({ stop: () => { if (carTimer) clearTimeout(carTimer); } });

    // Layer 6: Cup clink — random rare event every 30-90s
    let clinkTimer: number | null = null;
    const scheduleClink = () => {
      const delay = 30000 + Math.random() * 60000;
      clinkTimer = window.setTimeout(() => {
        if (!audioCtx || !masterGain) return;
        const t0 = audioCtx.currentTime;
        // Two short FM-ish blips simulating ceramic clink
        const osc = audioCtx.createOscillator();
        osc.type = "sine"; osc.frequency.value = 2200;
        const g = audioCtx.createGain(); g.gain.value = 0;
        const hpf = audioCtx.createBiquadFilter();
        hpf.type = "highpass"; hpf.frequency.value = 1500;
        osc.connect(hpf); hpf.connect(g); g.connect(masterGain);
        g.gain.setValueAtTime(0, t0);
        g.gain.linearRampToValueAtTime(0.10, t0 + 0.005);
        g.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.35);
        osc.frequency.setValueAtTime(2200, t0);
        osc.frequency.exponentialRampToValueAtTime(1800, t0 + 0.35);
        osc.start(t0); osc.stop(t0 + 0.4);
        scheduleClink();
      }, delay);
    };
    scheduleClink();
    built.push({ stop: () => { if (clinkTimer) clearTimeout(clinkTimer); } });

    return built;
  }

  // A10: door-bell chime on scene change — exposed for FilmFrame transitions to call
  (window as any).__playDoorBell = () => {
    if (!audioCtx || !masterGain || !isOn) return;
    const t0 = audioCtx.currentTime;
    // Two sine waves at 1100 and 1650 Hz, harmonic-ish — quick ceramic ring
    const f1 = 1100, f2 = 1650;
    [f1, f2].forEach((freq, idx) => {
      const o = audioCtx!.createOscillator();
      o.type = "sine"; o.frequency.value = freq;
      const g = audioCtx!.createGain(); g.gain.value = 0;
      o.connect(g); g.connect(masterGain!);
      const peak = idx === 0 ? 0.20 : 0.12;
      g.gain.setValueAtTime(0, t0);
      g.gain.linearRampToValueAtTime(peak, t0 + 0.01);
      g.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.9);
      o.start(t0); o.stop(t0 + 1.0);
    });
  };

  async function turnOn() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      masterGain = audioCtx.createGain();
      masterGain.gain.value = 0.0;
      masterGain.connect(audioCtx.destination);
    }
    if (audioCtx.state === "suspended") await audioCtx.resume();
    if (layers.length === 0) layers = buildLayers();
    if (masterGain) {
      masterGain.gain.cancelScheduledValues(audioCtx.currentTime);
      masterGain.gain.setValueAtTime(masterGain.gain.value, audioCtx.currentTime);
      masterGain.gain.linearRampToValueAtTime(0.7, audioCtx.currentTime + 0.6);
    }
    isOn = true;
    update();
  }

  async function turnOff() {
    if (audioCtx && masterGain) {
      masterGain.gain.cancelScheduledValues(audioCtx.currentTime);
      masterGain.gain.setValueAtTime(masterGain.gain.value, audioCtx.currentTime);
      masterGain.gain.linearRampToValueAtTime(0.0, audioCtx.currentTime + 0.4);
    }
    isOn = false;
    update();
  }

  function update() {
    const btn = document.getElementById("ambient-toggle");
    if (!btn) return;
    btn.setAttribute("data-on", String(isOn));
    const state = btn.querySelector(".ambient-state");
    if (state) state.textContent = isOn ? "on" : "off";
    try { localStorage.setItem("ambientAudio", isOn ? "on" : "off"); } catch {}
  }

  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("ambient-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      if (isOn) turnOff(); else turnOn();
    });
    // Persisted state — but don't auto-start audio (browser autoplay policy)
    try {
      const saved = localStorage.getItem("ambientAudio");
      if (saved === "on") {
        // Visually indicate; will resume on first interaction
        btn.setAttribute("data-on", "true");
        const state = btn.querySelector(".ambient-state");
        if (state) state.textContent = "tap to resume";
      }
    } catch {}
  });
</script>
