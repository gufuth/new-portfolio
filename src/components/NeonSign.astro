---
interface Props {
  label: string;
  color: "work" | "about" | "hearsay" | "open";
  href: string;
  ariaLabel: string;
  flickerDelay?: string;
  large?: boolean;
}
const { label, color, href, ariaLabel, flickerDelay = "0s", large = false } = Astro.props;
---
<a
  href={href}
  class:list={["neon-sign", `neon-${color}`, "magnetic", "fade-up", large && "neon-large"]}
  style={`animation-delay: ${flickerDelay};`}
  aria-label={ariaLabel}
  data-astro-prefetch
>
  <span class="label flicker" style={`animation-delay: ${flickerDelay};`}>{label}</span>
</a>

<style>
  .neon-sign {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.6rem;
    border-radius: 2px;
    text-decoration: none;
    transition: transform 0.3s var(--ease-cinematic);
    will-change: transform;
  }
  .neon-large { padding: 1.2rem 3.2rem; }
  .neon-sign:hover { transform: scale(1.05); }
  .neon-sign:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 4px;
  }
  .label {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.2rem, 3vw, 2rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .neon-large .label { font-size: clamp(2rem, 6vw, 4rem); }
  .neon-work .label { color: var(--color-neon-work); }
  .neon-about .label { color: var(--color-neon-about); }
  .neon-hearsay .label { color: var(--color-neon-hearsay); }
  .neon-open .label {
    color: var(--color-neon-work);
    font-size: 0.85rem;
    letter-spacing: 0.3em;
  }
</style>
