---
import NeonText from "@/components/NeonText.astro";
interface Props {
  label: string;
  href: string;
  color: "work" | "about" | "hearsay";
  size: string;
  top: string;
  left: string;
  italic?: boolean;
  tracking?: string;
  weight?: number;
  flickerDelay?: string;
}
const {
  label, href, color, size, top, left,
  italic = false, tracking = "0.08em", weight = 900,
  flickerDelay = "0s"
} = Astro.props;
---
<a
  href={href}
  class:list={["neon-sign", "magnetic", `tint-${color}`]}
  style={`top: ${top}; left: ${left};`}
  aria-label={`${label}. Navigate.`}
  data-astro-prefetch
>
  <NeonText
    text={label}
    color={color}
    size={size}
    italic={italic}
    tracking={tracking}
    weight={weight}
    flickerDelay={flickerDelay}
  />
</a>

<style>
  .neon-sign {
    position: absolute;
    transform: translate(-50%, -50%);
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.3s var(--ease-cinematic), filter 0.3s var(--ease-cinematic);
    padding: 0.4em 0.8em;
    border-radius: 4px;
  }
  .neon-sign:hover { transform: translate(-50%, -50%) scale(1.04); filter: brightness(1.15); }
  .neon-sign:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 6px;
  }
  .tint-work { color: var(--color-neon-work); }
  .tint-about { color: var(--color-neon-about); }
  .tint-hearsay { color: var(--color-neon-hearsay); }
</style>
