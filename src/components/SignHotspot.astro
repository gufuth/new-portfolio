---
interface Props {
  label: string;
  href: string;
  color: "work" | "about" | "hearsay";
  ariaLabel: string;
  top: string;
  left: string;
  width: string;
  height: string;
  flickerDelay?: string;
  hoverCopy?: string;     /* in-world hover phrase replacing "→" */
}
const {
  label, href, color, ariaLabel,
  top, left, width, height,
  flickerDelay = "0s",
  hoverCopy = "Step inside"
} = Astro.props;
---
<a href={href} class:list={["hotspot", `tint-${color}`]} style={`top: ${top}; left: ${left}; width: ${width}; height: ${height};`} aria-label={ariaLabel} data-astro-prefetch data-color={color}>
  <span class="flicker" style={`animation-delay: ${flickerDelay};`} aria-hidden="true"></span>
  <span class="hover-copy" aria-hidden="true">{hoverCopy}</span>
  <span class="sr-only">{label}</span>
</a>

<style>
  .hotspot {
    position: absolute;
    display: block;
    cursor: none;            /* custom cursor takes over */
    text-decoration: none;
    z-index: 4;
  }
  /* SHARP IRREGULAR NEON FLICKER — not smooth pulse */
  .flicker {
    position: absolute;
    inset: -20%;
    background: radial-gradient(ellipse at center, currentColor 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(30px);
    mix-blend-mode: screen;
    opacity: 0.55;
    pointer-events: none;
    will-change: opacity;
    animation: neon-flicker 7s linear infinite;
  }
  @keyframes neon-flicker {
    0%, 18%, 22%, 25%, 53%, 57%, 100% { opacity: 0.55; }
    19% { opacity: 0.22; }
    20% { opacity: 0.65; }
    21% { opacity: 0.25; }
    23% { opacity: 0.60; }
    54% { opacity: 0.15; }
    55% { opacity: 0.70; }
    56% { opacity: 0.30; }
    62% { opacity: 0.85; }
    64% { opacity: 0.50; }
    66% { opacity: 0.78; }
    80% { opacity: 0.65; }
  }

  /* In-world hover copy — typewriter style, no arrows */
  .hover-copy {
    position: absolute;
    bottom: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    font-family: var(--font-mono);
    font-size: clamp(0.7rem, 1.05vw, 0.85rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: currentColor;
    text-shadow: 0 0 6px currentColor, 0 0 14px currentColor;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s var(--ease-cinematic), transform 0.3s var(--ease-cinematic);
  }

  /* Hover state — neon roars to life, copy appears */
  .hotspot:hover .flicker {
    opacity: 0.95;
    filter: blur(20px);
    animation-duration: 4s;
  }
  .hotspot:hover .hover-copy {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .hotspot:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 8px;
    cursor: pointer;
  }

  .tint-work    { color: var(--color-neon-work); }
  .tint-about   { color: var(--color-neon-about); }
  .tint-hearsay { color: var(--color-neon-hearsay); }

  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

  @media (prefers-reduced-motion: reduce) {
    .flicker { animation: none; opacity: 0.6; }
  }
</style>
