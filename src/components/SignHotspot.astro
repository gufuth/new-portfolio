---
interface Props {
  label: string;
  href: string;
  color: "work" | "about" | "hearsay";
  ariaLabel: string;
  top: string;
  left: string;
  width: string;
  height: string;
  labelPosition?: "above" | "below" | "right";
  pulseDelay?: string;
}
const {
  label, href, color, ariaLabel,
  top, left, width, height,
  labelPosition = "below",
  pulseDelay = "0s"
} = Astro.props;
---
<a
  href={href}
  class:list={["sign-hotspot", `tint-${color}`, "magnetic"]}
  style={`top: ${top}; left: ${left}; width: ${width}; height: ${height};`}
  aria-label={ariaLabel}
  data-astro-prefetch
>
  <span class="outline" style={`animation-delay: ${pulseDelay};`} aria-hidden="true"></span>
  <span class:list={["hint", `hint-${labelPosition}`]} aria-hidden="true">
    {label} <span class="arrow">→</span>
  </span>
  <span class="sr-only">{label}</span>
</a>

<style>
  .sign-hotspot {
    position: absolute;
    display: block;
    cursor: pointer;
    transition: transform 0.4s var(--ease-cinematic);
    will-change: transform;
    color: var(--color-cream);
  }

  /* Visible neon outline — persistent, pulsing */
  .outline {
    position: absolute;
    inset: -4%;
    border: 1.5px solid currentColor;
    border-radius: 6px;
    box-shadow:
      0 0 12px currentColor,
      0 0 24px currentColor,
      inset 0 0 8px rgba(255, 255, 255, 0.15);
    opacity: 0.85;
    animation: outline-breathe 3.6s var(--ease-cinematic) infinite;
    pointer-events: none;
    will-change: opacity, box-shadow;
  }

  /* Visible hint label */
  .hint {
    position: absolute;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(0.75rem, 1.4vw, 1rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: currentColor;
    text-shadow: 0 0 8px currentColor, 0 0 18px currentColor;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0.85;
  }
  .hint-below { top: calc(100% + 8px); left: 50%; transform: translateX(-50%); }
  .hint-above { bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%); }
  .hint-right { left: calc(100% + 12px); top: 50%; transform: translateY(-50%); }
  .arrow { display: inline-block; margin-left: 0.25em; }

  /* Hover state — intensify */
  .sign-hotspot:hover {
    transform: scale(1.02);
  }
  .sign-hotspot:hover .outline {
    opacity: 1;
    box-shadow:
      0 0 18px currentColor,
      0 0 40px currentColor,
      0 0 72px currentColor,
      inset 0 0 12px rgba(255, 255, 255, 0.3);
    animation-duration: 1.6s;
  }
  .sign-hotspot:hover .hint {
    opacity: 1;
    text-shadow: 0 0 12px currentColor, 0 0 30px currentColor;
  }
  .sign-hotspot:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 8px;
  }

  .tint-work { color: var(--color-neon-work); }
  .tint-about { color: var(--color-neon-about); }
  .tint-hearsay { color: var(--color-neon-hearsay); }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    overflow: hidden; clip: rect(0,0,0,0);
  }

  @keyframes outline-breathe {
    0%, 100% {
      opacity: 0.70;
      box-shadow: 0 0 10px currentColor, 0 0 20px currentColor, inset 0 0 6px rgba(255, 255, 255, 0.12);
    }
    50% {
      opacity: 0.95;
      box-shadow: 0 0 16px currentColor, 0 0 32px currentColor, 0 0 56px currentColor, inset 0 0 10px rgba(255, 255, 255, 0.2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .outline { animation: none; opacity: 0.85; }
  }
</style>
