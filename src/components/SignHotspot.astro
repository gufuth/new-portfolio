---
interface Props {
  label: string; href: string;
  color: "work" | "about" | "hearsay";
  ariaLabel: string;
  top: string; left: string; width: string; height: string;
  flickerDelay?: string;
  hoverCopy?: string;
  hintPosition?: "above" | "below" | "right" | "left";
}
const {
  label, href, color, ariaLabel,
  top, left, width, height,
  flickerDelay = "0s",
  hoverCopy = "Step inside",
  hintPosition = "above",
} = Astro.props;
---
<a href={href}
   class:list={["hotspot", `tint-${color}`]}
   style={`top: ${top}; left: ${left}; width: ${width}; height: ${height}; --flicker-delay: ${flickerDelay};`}
   aria-label={ariaLabel}
   data-astro-prefetch>
  <span class="flicker" aria-hidden="true"></span>
  <span class:list={["hover-copy", `hint-${hintPosition}`]} aria-hidden="true">{hoverCopy}</span>
  <span class="sr-only">{label}</span>
</a>

<style>
  .hotspot { position: absolute; display: block; cursor: pointer; text-decoration: none; z-index: 5; }

  /* Flicker layer — starts hidden, entry-pulse fires once at --flicker-delay, then ambient flicker loops */
  .flicker {
    position: absolute; inset: -22%;
    background: radial-gradient(ellipse at center, currentColor 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(32px);
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
    animation:
      entry-pulse 1.5s var(--ease-cinematic) var(--flicker-delay, 0s) 1 forwards,
      neon-flicker 9s linear calc(var(--flicker-delay, 0s) + 1.5s) infinite;
  }
  @keyframes entry-pulse {
    /* The sign wakes up: dark → flash bright (alive, interactive) → settle to ambient glow */
    0%   { opacity: 0; }
    30%  { opacity: 0.92; }
    60%  { opacity: 0.40; }
    100% { opacity: 0.32; }
  }
  @keyframes neon-flicker {
    /* RESTRAINED ambient flicker per Veo source pattern */
    0%, 100% { opacity: 0.32; }
    34% { opacity: 0.34; }
    35% { opacity: 0.12; }
    36% { opacity: 0.30; }
    37% { opacity: 0.20; }
    38% { opacity: 0.34; }
    72% { opacity: 0.34; }
    73% { opacity: 0.18; }
    74% { opacity: 0.40; }
  }

  /* Hover copy */
  .hover-copy {
    position: absolute;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-cream);
    background: rgba(10, 9, 8, 0.7);
    backdrop-filter: blur(8px);
    padding: 0.35rem 0.7rem;
    border: 1px solid color-mix(in srgb, currentColor 60%, transparent);
    border-radius: 2px;
    white-space: nowrap;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s var(--ease-cinematic), transform 0.3s var(--ease-cinematic);
    box-shadow: 0 0 12px color-mix(in srgb, currentColor 40%, transparent);
  }
  .hint-above { bottom: calc(100% + 12px); left: 50%; transform: translateX(-50%) translateY(-4px); }
  .hint-below { top: calc(100% + 12px); left: 50%; transform: translateX(-50%) translateY(4px); }
  .hint-right { left: calc(100% + 12px); top: 50%; transform: translateY(-50%) translateX(4px); }
  .hint-left  { right: calc(100% + 12px); top: 50%; transform: translateY(-50%) translateX(-4px); }

  .hotspot:hover .flicker {
    opacity: 0.85 !important;
    filter: blur(20px);
    animation-duration: 4s, 4s;
  }
  .hotspot:hover .hover-copy { opacity: 1; transform: translateX(-50%) translateY(0); }
  .hotspot:hover .hint-right { transform: translateY(-50%) translateX(0); }
  .hotspot:hover .hint-left { transform: translateY(-50%) translateX(0); }
  .hotspot:focus-visible { outline: 2px solid var(--color-cream); outline-offset: 8px; }

  .tint-work { color: var(--color-neon-work); }
  .tint-about { color: var(--color-neon-about); }
  .tint-hearsay { color: var(--color-neon-hearsay); }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

  @media (prefers-reduced-motion: reduce) {
    .flicker { animation: none; opacity: 0.4; }
  }
</style>
