---
interface Props {
  label: string; href: string;
  color: "work" | "about" | "hearsay";
  ariaLabel: string;
  top: string; left: string; width: string; height: string;
  flickerDelay?: string;
}
const {
  label, href, color, ariaLabel,
  top, left, width, height,
  flickerDelay = "0s",
} = Astro.props;
---
<a href={href}
   class:list={["hotspot", `tint-${color}`]}
   style={`top: ${top}; left: ${left}; width: ${width}; height: ${height}; --flicker-delay: ${flickerDelay};`}
   aria-label={ariaLabel}
   data-astro-prefetch>
  <span class="flicker" aria-hidden="true"></span>
  <span class="sr-only">{label}</span>
</a>

<style>
  .hotspot { position: absolute; display: block; cursor: pointer; text-decoration: none; z-index: 5; }

  /* Diegetic affordance: glow on the sign itself. No text labels. No tooltips. */
  .flicker {
    position: absolute; inset: -22%;
    background: radial-gradient(ellipse at center, currentColor 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(32px);
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
    animation:
      entry-pulse 1.5s var(--ease-cinematic) var(--flicker-delay, 0s) 1 forwards,
      neon-flicker 9s linear calc(var(--flicker-delay, 0s) + 1.5s) infinite;
  }
  @keyframes entry-pulse {
    /* Sign wakes up on entry zoom: dark → flash bright → settle to silence */
    0%   { opacity: 0; }
    30%  { opacity: 0.85; }
    60%  { opacity: 0.20; }
    100% { opacity: 0.04; }
  }
  @keyframes neon-flicker {
    /* SILENT ambient — sign is invisible at rest. Only flickers in occasional brief moments. */
    0%, 100% { opacity: 0.04; }
    34% { opacity: 0.06; }
    35% { opacity: 0.02; }
    36% { opacity: 0.05; }
    37% { opacity: 0.04; }
    38% { opacity: 0.06; }
    72% { opacity: 0.05; }
    73% { opacity: 0.02; }
    74% { opacity: 0.06; }
  }

  /* On hover: the SIGN intensifies. No text label. No tooltip. The world reacts. */
  .hotspot:hover .flicker {
    opacity: 0.85 !important;
    filter: blur(18px);
    animation-duration: 4s, 4s;
  }
  .hotspot:focus-visible { outline: 2px solid var(--color-cream); outline-offset: 8px; }

  .tint-work { color: var(--color-neon-work); }
  .tint-about { color: var(--color-neon-about); }
  .tint-hearsay { color: var(--color-neon-hearsay); }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

  @media (prefers-reduced-motion: reduce) {
    .flicker { animation: none; opacity: 0.4; }
  }
</style>
