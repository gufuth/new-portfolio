---
interface Props {
  label: string;
  href: string;
  color: "work" | "about" | "hearsay";
  ariaLabel: string;
  top: string;
  left: string;
  width: string;
  height: string;
  pulseDelay?: string;     /* for first-visit sequential pulse */
  hintPosition?: "above" | "below" | "right" | "left";
}
const {
  label, href, color, ariaLabel,
  top, left, width, height,
  pulseDelay = "0s",
  hintPosition = "below"
} = Astro.props;
---
<a
  href={href}
  class:list={["hotspot", `tint-${color}`]}
  style={`top: ${top}; left: ${left}; width: ${width}; height: ${height};`}
  aria-label={ariaLabel}
  data-astro-prefetch
>
  <!-- Color-matched glow that intensifies the painted neon underneath. Uses screen blend. -->
  <span class="glow" style={`animation-delay: ${pulseDelay};`} aria-hidden="true"></span>

  <!-- Tiny corner indicator — persistent but subtle -->
  <span class="corner-tick" aria-hidden="true">→</span>

  <!-- Hover label — neon-styled, appears outside the painted sign -->
  <span class:list={["hover-label", `hint-${hintPosition}`]} aria-hidden="true">
    {label} <span class="arrow">→</span>
  </span>

  <span class="sr-only">{label}</span>
</a>

<style>
  .hotspot {
    position: absolute;
    display: block;
    cursor: pointer;
    text-decoration: none;
  }

  /* Color-matched halo that intensifies the painted neon. mix-blend-mode: screen so it brightens. */
  .glow {
    position: absolute;
    inset: -15%;
    background: radial-gradient(ellipse at center, currentColor 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(24px);
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-cinematic), filter 0.4s var(--ease-cinematic);
    will-change: opacity, filter;
    animation: first-pulse 1.4s var(--ease-cinematic) 1 both;
  }

  /* First-visit pulse: each hotspot briefly glows on page load (sequential via animation-delay) */
  @keyframes first-pulse {
    0%   { opacity: 0; filter: blur(28px); }
    40%  { opacity: 0.6; filter: blur(20px); }
    100% { opacity: 0; filter: blur(28px); }
  }

  /* Tiny corner indicator: small arrow at top-right of hotspot, color-matched */
  .corner-tick {
    position: absolute;
    top: -6%;
    right: -2%;
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1vw, 0.85rem);
    color: currentColor;
    opacity: 0;
    text-shadow: 0 0 6px currentColor, 0 0 12px currentColor;
    pointer-events: none;
    animation: tick-in 1.2s var(--ease-cinematic) 2.2s 1 both;
  }
  @keyframes tick-in {
    from { opacity: 0; transform: translate(-4px, 4px); }
    to   { opacity: 0.55; transform: translate(0, 0); }
  }

  /* Hover label: neon-styled, appears outside the painted sign */
  .hover-label {
    position: absolute;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: clamp(0.7rem, 1.3vw, 1rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: currentColor;
    text-shadow: 0 0 8px currentColor, 0 0 18px currentColor, 0 0 36px color-mix(in srgb, currentColor 50%, transparent);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s var(--ease-cinematic), transform 0.3s var(--ease-cinematic);
  }
  .hint-below  { top: calc(100% + 6px);    left: 50%;            transform: translateX(-50%) translateY(4px); }
  .hint-above  { bottom: calc(100% + 6px); left: 50%;            transform: translateX(-50%) translateY(-4px); }
  .hint-right  { left: calc(100% + 8px);   top: 50%;             transform: translateY(-50%) translateX(4px); }
  .hint-left   { right: calc(100% + 8px);  top: 50%;             transform: translateY(-50%) translateX(-4px); }
  .arrow       { display: inline-block; margin-left: 0.2em; }

  /* Hover state — intensify glow, surface label, brighten tick */
  .hotspot:hover .glow {
    opacity: 0.85;
    filter: blur(18px);
    animation: none;
  }
  .hotspot:hover .hover-label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .hotspot:hover .corner-tick {
    opacity: 1;
    animation: none;
  }

  .hotspot:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 8px;
  }

  /* Color tints */
  .tint-work    { color: var(--color-neon-work); }
  .tint-about   { color: var(--color-neon-about); }
  .tint-hearsay { color: var(--color-neon-hearsay); }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .glow { animation: none; opacity: 0; }
    .corner-tick { animation: none; opacity: 0.55; }
  }
</style>
